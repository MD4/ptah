{
  "name": "@ptah-app/lib-models",
  "version": "0.3.0",
  "private": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsup --onSuccess \"tsc --ignoreConfig --types node --allowSyntheticDefaultImports --emitDeclarationOnly --declaration --declarationMap src/index.ts --outDir dist\"",
    "clean": "rm -rf dist",
    "dev": "tsup --dts --watch --onSuccess \"tsc --ignoreConfig --types node --allowSyntheticDefaultImports --emitDeclarationOnly --declaration --declarationMap src/index.ts --outDir dist\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "preset": "jest-presets/jest/node"
  },
  "devDependencies": {
    "@ptah-app/config-jest": "workspace:*",
    "@ptah-app/config-ts": "workspace:*",
    "@types/node": "^25.6.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "jest-presets": "npm:@ptah-app/config-jest@*",
    "@types/jest": "^30.0.0"
  },
  "dependencies": {
    "@ptah-app/lib-logger": "workspace:*",
    "zod": "^4.3.6"
  }
}
