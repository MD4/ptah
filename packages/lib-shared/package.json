{
  "name": "@ptah-app/lib-shared",
  "version": "0.3.0",
  "private": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsup --onSuccess \"tsc --ignoreConfig --types node --allowSyntheticDefaultImports --emitDeclarationOnly --declaration --declarationMap src/index.ts --outDir dist\"",
    "clean": "rm -rf dist",
    "dev": "tsup --dts --watch --onSuccess \"tsc --ignoreConfig --types node --allowSyntheticDefaultImports --emitDeclarationOnly --declaration --declarationMap src/index.ts --outDir dist\"",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --passWithNoTests --coverage"
  },
  "jest": {
    "preset": "jest-presets/jest/node",
    "moduleNameMapper": {
      "^@ptah-app/lib-logger$": "<rootDir>/../lib-logger/src/index.ts",
      "^@ptah-app/lib-models$": "<rootDir>/../lib-models/src/index.ts"
    }
  },
  "devDependencies": {
    "@ptah-app/config-jest": "workspace:*",
    "@ptah-app/config-ts": "workspace:*",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "jest-presets": "npm:@ptah-app/config-jest@*"
  },
  "dependencies": {
    "@kalm/ipc": "^7.0.0",
    "@ptah-app/lib-domains": "workspace:^",
    "@ptah-app/lib-logger": "workspace:*",
    "@ptah-app/lib-models": "workspace:*",
    "kalm": "^7.0.0",
    "zod": "^4.3.6"
  }
}
