{
  "name": "@ptah-app/ui-admin",
  "version": "0.2.4",
  "private": false,
  "scripts": {
    "start": "serve --single dist",
    "build": "vite build",
    "clean": "rm -rf dist",
    "dev": "vite --host 0.0.0.0 --port 3001 --clearScreen false",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "jest": {
    "preset": "jest-presets/jest/browser",
    "moduleNameMapper": {
      "^uuid$": "<rootDir>/__mocks__/uuid.js",
      "^@ptah-app/lib-utils$": "<rootDir>/../../packages/lib-utils/src/index.ts",
      "^@ptah-app/lib-models$": "<rootDir>/../../packages/lib-models/src/index.ts",
      "^@ptah-app/lib-domains$": "<rootDir>/../../packages/lib-domains/src/index.ts",
      "^@ptah-app/lib-logger$": "<rootDir>/../../packages/lib-logger/src/index.ts"
    }
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.2",
    "@ptah-app/lib-domains": "workspace:^",
    "@ptah-app/lib-logger": "workspace:^",
    "@ptah-app/lib-models": "workspace:*",
    "@ptah-app/lib-utils": "workspace:*",
    "@simbathesailor/use-what-changed": "^2.0.0",
    "@tanstack/react-query": "^5.100.14",
    "@types/react-transition-group": "^4.4.12",
    "@types/uuid": "^11.0.0",
    "@xyflow/react": "^12.10.2",
    "antd": "^6.5.0",
    "antd-zod": "^8.0.0",
    "axios": "^1.18.1",
    "fast-equals": "^6.0.0",
    "masonic": "^4.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "react-transition-group": "^4.4.5",
    "serve": "^14.2.6",
    "socket.io-react-hook": "^2.4.5",
    "type-fest": "^5.8.0",
    "usehooks-ts": "^3.1.1",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ptah-app/config-jest": "workspace:*",
    "@ptah-app/config-ts": "workspace:*",
    "@types/events": "^3.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jest-presets": "npm:@ptah-app/config-jest@*",
    "sass": "^1.101.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
