{
  "name": "ptah-app",
  "private": true,
  "scripts": {
    "start": "cd apps/app && pnpm start",
    "start:ui": "cd apps/ui-admin && pnpm start",
    "build": "turbo build --force",
    "clean": "turbo clean && rm -Rf .turbo **/*/.turbo",
    "dev": "turbo dev --cache=local:r,remote:r  --continue --concurrency 20",
    "format": "biome format",
    "format:fix": "biome format --write",
    "check": "biome check",
    "check:fix": "biome check --write",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "allcheck": "pnpm format && pnpm check && pnpm typecheck && pnpm test",
    "release": "bash scripts/release.sh",
    "release:dry": "bash scripts/release.sh --dry-run",
    "publish-packages": "bash scripts/release.sh",
    "test:coverage": "turbo test:coverage",
    "link:global": "pnpm --filter @ptah-app/app run link:global && pnpm --filter @ptah-app/ui-cli run link:global"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@changesets/cli": "^2.31.0",
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2",
    "turbo": "^2.9.14"
  },
  "packageManager": "pnpm@9.15.4"
}
